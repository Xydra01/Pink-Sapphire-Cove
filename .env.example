# Dragon Cave: application "Private Key" from https://dragcave.net/api/manage
# (not the OAuth client id). Required for legacy /api/{key}/json/...
DC_API_KEY=
# Optional v2-only: full Authorization header value (Bearer is added if you omit it).
# Example: DC_AUTHORIZATION="Bearer your_private_key"
# If unset, v2 uses: Authorization: Bearer <DC_API_KEY>
DC_AUTHORIZATION=
MONGODB_URI=
MONGODB_DB=
